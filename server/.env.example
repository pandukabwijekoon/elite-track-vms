# EliteTrack Backend - Environment Blueprint
# Copy this to .env and fill in your credentials

# System Configuration
PORT=5000
NODE_ENV=development

# Database (MongoDB Atlas URI)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/elitetrack

# Authentication (Secure Random Strings)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=30d

# Mail Engine (Nodemailer Configuration)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_NAME=EliteTrack Performance
FROM_EMAIL=no-reply@elitetrack.com
